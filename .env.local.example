# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — used server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your deployed URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe price ID for Pro plan — https://dashboard.stripe.com/products
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
